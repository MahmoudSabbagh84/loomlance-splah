{
  "name": "loomlance-splash",
  "private": true,
  "version": "1.0.0",
  "description": "LoomLance marketing + signup site (static, Tailwind-built).",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./app.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./app.css --watch",
    "build": "npm run build:css",
    "build:blog": "node scripts/build-blog.mjs",
    "test": "node --test scripts/*.test.mjs"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "autoprefixer": "^10.4.19",
    "marked": "^18.0.5",
    "postcss": "^8.4.39",
    "sanitize-html": "^2.17.5",
    "tailwindcss": "^3.4.4"
  }
}
